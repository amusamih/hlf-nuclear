{
  "name": "nuclear-assurance-sandbox",
  "private": true,
  "version": "0.1.0",
  "devDependencies": {
    "@browsermcp/mcp": "^0.1.3",
    "@types/node": "^22.10.2",
    "typescript": "^5.6.3"
  },
  "workspaces": [
    "apps/*",
    "evaluation/*",
    "packages/*",
    "smart-contracts/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:shared": "npm run build --workspace @prototype/shared",
    "build:shared:chaincode": "npm run build:chaincode --workspace @prototype/shared",
    "build:chaincode": "npm run build --workspace @prototype/chaincode",
    "build:backend": "npm run build --workspace @prototype/backend",
    "build:scenario-runner": "npm run build --workspace @prototype/scenario-runner",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:backend": "npm run start:dev --workspace @prototype/backend",
    "dev:frontend": "npm run dev --workspace @prototype/frontend",
    "fabric:up": "powershell -ExecutionPolicy Bypass -File ./infra/fabric/scripts/up-network.ps1",
    "fabric:down": "powershell -ExecutionPolicy Bypass -File ./infra/fabric/scripts/down-network.ps1"
  }
}
